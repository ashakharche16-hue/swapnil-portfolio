# ----------------------------------------------------------------------------
# Environment variables. Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets. (Slices 2+ will use these.)
# ----------------------------------------------------------------------------

# Supabase (added in Slice 2). Get these from your Supabase project:
#   Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key — never expose to the client. (used by server-side services)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for SEO/canonicals in Slice 8), e.g. https://example.com
NEXT_PUBLIC_SITE_URL=
